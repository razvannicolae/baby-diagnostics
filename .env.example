# Database
DATABASE_URL=postgresql+asyncpg://babybio:babybio_dev@localhost:5432/babybio

# Auth
JWT_SECRET_KEY=          # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
GOOGLE_CLIENT_ID=        # From Google Cloud Console

# Field Encryption (Fernet / AES-256)
FIELD_ENCRYPTION_KEY=    # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# LLM
ANTHROPIC_API_KEY=       # From Anthropic Console
LLM_PROVIDER=anthropic   # anthropic | lmstudio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_API_KEY=        # Optional — only if "Require Authentication" is enabled in LM Studio
LMSTUDIO_MODEL=qwen3.6   # Model name as shown in LM Studio (must be loaded/running)

# CV
CALIBRATION_PATH=app/cv/calibration/default.yaml

# App
APP_ENV=development      # development | production
CORS_ORIGINS=http://localhost:5173
